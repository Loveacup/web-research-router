# WRR (Web Research Router) 环境变量配置示例
#
# 使用方法：
#   1. 复制此文件: cp .env.example ~/.hermes/.env
#   2. 填写你的 API key 和配置
#   3. wrr-cli.py 会自动加载 ~/.hermes/.env
#
# 或指定自定义路径:
#   export WRR_ENV=/path/to/custom.env
#   wrr-cli.py --env /path/to/custom.env search "query"

# ══════════════════════════════════════════════════════════════════════
# Tier 1: API Key / Token 配置
# ══════════════════════════════════════════════════════════════════════

# Exa AI 搜索引擎
# 申请地址: https://exa.ai
EXA_API_KEY=your_exa_api_key_here

# Brave Search API
# 申请地址: https://brave.com/search/api/
# 主用 key（推荐）:
BRAVE_API_KEY=your_brave_api_key_here
# 或备用 key（向后兼容 Hermes 内置 brave）:
# BRAVE_SEARCH_API_KEY=your_brave_api_key_here

# GitHub Token
# 用于 GitHub 仓库搜索和 Skill Discovery
# 申请地址: https://github.com/settings/tokens
# 需要权限: public_repo (或 repo for private repos)
GITHUB_TOKEN=your_github_token_here

# ══════════════════════════════════════════════════════════════════════
# Tier 2: 本地服务配置
# ══════════════════════════════════════════════════════════════════════

# SearXNG 本地实例 URL
# 安装说明: https://docs.searxng.org/
# Docker 快速启动:
#   docker run -d -p 32080:8080 searxng/searxng
SEARXNG_URL=http://127.0.0.1:32080

# ══════════════════════════════════════════════════════════════════════
# 可选配置
# ══════════════════════════════════════════════════════════════════════

# Community 引擎外部依赖（需手动安装）
# 1. Agent-Reach (opencli): npm install -g opencli
#    仓库: https://github.com/Panniantong/Agent-Reach
# 2. last30days (英文): git clone https://github.com/mvanhorn/last30days-skill ~/code/last30days-skill
# 3. last30days (中文): git clone https://github.com/Jesseovo/last30days-skill-cn ~/code/last30days-skill-cn

# Academic 引擎：paper-search-mcp 地址（可选）
# 仓库: https://github.com/openags/paper-search-mcp
# PAPER_SEARCH_MCP_URL=http://127.0.0.1:8000

# 显式指定 .env 路径（通常不需要设置，优先级低于 --env 参数）
# WRR_ENV=/path/to/custom.env

# Community 引擎：是否包含 last30days 技能（默认根据触发词启用）
# COMMUNITY_INCLUDE_LAST30DAYS=False

# Academic 引擎：是否包含 arXiv 预印本（默认 False，仅 OpenAlex + S2）
# ACADEMIC_INCLUDE_ARXIV=False

# ══════════════════════════════════════════════════════════════════════
# 验证配置
# ══════════════════════════════════════════════════════════════════════
#
# 配置完成后运行:
#   wrr-cli.py doctor
#
# 检查指定引擎:
#   wrr-cli.py doctor --engine exa
#   wrr-cli.py doctor --tier 1
#
# JSON 输出:
#   wrr-cli.py doctor --json
